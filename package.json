{
  "name": "opensql",
  "displayName": "openQL", 
  "description": "Natural-language SQL agent for VS Code — chat with your database using OpenAI, Anthropic, Azure OpenAI, or Google Gemini.",
  "version": "1.0.3",
  "icon": "images/logo.png",
  "publisher": "h5sh",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "sql",
    "nl2sql",
    "database",
    "ai",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "postgres",
    "mysql"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/H5SH/nlsql-vscode"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "vanna-sql-sidebar",
          "title": "openQL",
          "icon": "$(database)"
        }
      ]
    },
    "views": {
      "vanna-sql-sidebar": [
        {
          "type": "webview",
          "id": "vanna-sql.chatView",
          "name": "openQL"
        }
      ]
    },
    "commands": [
      {
        "command": "vanna-sql.openChat",
        "title": "openQL: Open Chat"
      }
    ],
    "configuration": {
      "title": "opneQL Agent",
      "properties": {
        "vannaSql.modelName": {
          "type": "string",
          "default": "gpt-4o",
          "description": "The Model Name to use (e.g. gpt-4o, claude-3-sonnet-20240229, gemini-1.5-pro). The provider will be automatically detected."
        },
        "vannaSql.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for your chosen provider."
        },
        "vannaSql.useAzure": {
          "type": "boolean",
          "default": false,
          "description": "Whether to use Azure OpenAI instead of standard OpenAI (only applies to gpt models)."
        },
        "vannaSql.endpoint": {
          "type": "string",
          "default": "",
          "description": "Endpoint (Optional, required for Azure, or endpoint URL for Ollama)."
        },
        "vannaSql.sqlConnectionUrl": {
          "type": "string",
          "default": "",
          "description": "Database Connection URL (e.g. postgresql://user:password@localhost:5432/db)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.49.0",
    "typescript": "^5.2.2"
  }
}
